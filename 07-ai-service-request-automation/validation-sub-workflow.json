              "type": "string"
            },
            {
              "id": "2aa0b696-4483-417d-b7ab-3dce843fb672",
              "name": "valid",
              "value": "={{\n  !!$json.request?.trim() && !!$json.name?.trim() && /^[\\d\\s()+-]{7,20}$/.test($json.phone?.trim() || \"\")\n}}",
              "type": "boolean"
            },
            {
              "id": "5560e881-9741-41a8-aa57-4d279aae4aaa",
              "name": "error_reason",
              "value": "={{\n  !$json.name?.trim()\n    ? \"missing name\"\n    : !$json.phone?.trim()\n      ? \"missing phone\"\n      : !/^[\\d\\s()+-]{7,20}$/.test($json.phone?.trim() || \"\")\n        ? \"invalid phone\"\n        : !$json.request?.trim()\n          ? \"missing request\"\n          : \"\"\n}}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
