    {
      "parameters": {
        "jsCode": "const raw = $json.output || $json.text || $json.response || $json.message || '';\n\nlet cleaned = raw;\n\nif (typeof cleaned === 'string') {\n  cleaned = cleaned\n    .replace(/^```json\\s*/i, '')\n    .replace(/^```\\s*/i, '')\n    .replace(/```$/i, '')\n    .trim();\n}\n\nlet parsed;\n\ntry {\n  parsed = typeof cleaned === 'string' ? JSON.parse(cleaned) : cleaned;\n} catch (e) {\n  parsed = {\n    ai_error: true,\n    error_reason: \"AI JSON parse failed\"\n  };\n}\n\nreturn [\n  {\n    json: {\n      ai_error: parsed.ai_error || false,\n      error_reason: parsed.error_reason || \"\",\n      urgency: parsed.urgency || \"\",\n      urgency_reason: parsed.reason || \"\",\n      urgency_confidence: parsed.confidence || 0\n    }\n  }\n];"
      },
