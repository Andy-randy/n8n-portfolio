    {
      "parameters": {
        "jsCode": "const htmlItems = $input.all();\nconst competitors = $('Competitors list').all().map(item => item.json);\n\nfunction normalizeName(value) {\n  return String(value || '')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .toLowerCase();\n}\n\nfunction normalizePrice(value) {\n  const raw = String(value || '').replace(/\\s+/g, ' ').trim();\n  const digits = raw.replace(/\\D/g, '');\n  const numeric = digits ? Number(digits) : null;\n\n  return {\n    raw,\n    numeric: Number.isFinite(numeric) ? numeric : null,\n  };\n}\n\nconst result = [];\n\nhtmlItems.forEach((item, index) => {\n  const names = Array.isArray(item.json.name) ? item.json.name : [];\n  const prices = Array.isArray(item.json.price) ? item.json.price : [];\n  const competitorData = competitors[index];\n  \n  if (!competitorData) return;\n\n  names.forEach((name, index) => {\n    const productName = String(name || '').replace(/\\s+/g, ' ').trim();\n    const price = normalizePrice(prices[index]);\n\n    if (!productName || !price.raw || price.numeric === null) return;\n\n    const normalizedName = normalizeName(productName);\n    const productKey = `${competitorData.competitor}::${normalizedName}`;\n\n    result.push({\n      json: {\n        date: new Date().toISOString().split('T')[0],\n        competitor: competitorData.competitor,\n        url: competitorData.url,\n        product_name: productName,\n        normalized_product_name: normalizedName,\n        product_key: productKey,\n        price: price.raw,\n        price_num: price.numeric,\n      },\n    });\n  });\n});\n\nreturn result;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -176,
        -32
      ],
      "id": "8431346f-e179-4f98-b862-e52de43bbe1f",
      "name": "Prepare products"
    },
    {
      "parameters": {
        "jsCode": "const products = Array.isArray($json.data) ? $json.data : [];\nconst competitors = $('Competitors list').all().map(item => item.json);\nconst maxItemsPerCompetitor = 10;\n\nconst grouped = products.reduce((acc, product) => {\n  const competitor = product.competitor || 'Без конкурента';\n  if (!acc[competitor]) acc[competitor] = [];\n  acc[competitor].push(product);\n  return acc;\n}, {});\n\nconst lines = [];\n\ncompetitors.forEach((competitorData) => {\n  const competitor = competitorData.competitor;\n  const items = grouped[competitor] || [];\n\n  lines.push(`🏪 ${competitor} — найдено ${items.length}`);\n\n  if (items.length === 0) {\n    lines.push('Товары не найдены. Проверь CSS-селекторы или загрузку товаров через JavaScript.');\n    lines.push('');\n    return;\n  }\n\n  items.slice(0, maxItemsPerCompetitor).forEach((product, index) => {\n    lines.push(`${index + 1}. ${product.product_name} — ${product.price}`);\n  });\n\n  if (items.length > maxItemsPerCompetitor) {\n    lines.push(`...и еще ${items.length - maxItemsPerCompetitor} товаров`);\n  }\n\n  lines.push('');\n});\n\nconst message = lines.join('\\n').trim();\nconst maxTelegramLength = 3800;\n\nreturn [\n  {\n    json: {\n      total_products: products.length,\n      total_competitors: competitors.length,\n      competitors_with_products: Object.keys(grouped).length,\n      message: message.length > maxTelegramLength\n        ? `${message.slice(0, maxTelegramLength)}\\n\\nСообщение обрезано, полный список смотри в таблице.`\n        : message,\n    },\n  },\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        192,
        -32
      ],
      "id": "2dcddde0-0dd5-4cc6-9537-88d737a03bbd",
      "name": "Build daily report"
    },
    {
      "parameters": {
        "jsCode": "const products = $('Prepare products').all().map(item => item.json);\nconst rows = $input.all().map(item => item.json).filter(row => Object.keys(row).length > 0);\n\nfunction toNumber(value) {\n  if (value === null || value === undefined || value === '') return null;\n  const digits = String(value).replace(/\\D/g, '');\n  const number = digits ? Number(digits) : null;\n  return Number.isFinite(number) ? number : null;\n}\n\nfunction rowTime(row) {\n  const value = row['Дата последнего обновления'] || row['Дата'] || '';\n  const timestamp = Date.parse(String(value).replace(' ', 'T'));\n  return Number.isFinite(timestamp) ? timestamp : 0;\n}\n\nfunction matches(row, product) {\n  if (row['Ключ']) return row['Ключ'] === product.product_key;\n  return row['Конкурент'] === product.competitor && row['Товар'] === product.product_name;\n}\n\nreturn products.map((current) => {\n  const relevantRows = rows\n    .filter(row => matches(row, current))\n    .sort((a, b) => rowTime(b) - rowTime(a));\n\n  const latest = relevantRows[0];\n  const oldPrice = latest ? latest['Цена'] : null;\n  const oldPriceNum = latest ? toNumber(latest['Цена числом'] || latest['Цена']) : null;\n  const newPriceNum = toNumber(current.price_num);\n  const changed = latest ? oldPriceNum !== newPriceNum : true;\n  const diff = oldPriceNum !== null && newPriceNum !== null ? newPriceNum - oldPriceNum : null;\n  const diffPercent = oldPriceNum && diff !== null ? (diff / oldPriceNum) * 100 : null;\n\n  return {\n    json: {\n      date: current.date,\n      competitor: current.competitor,\n      url: current.url,\n      product_name: current.product_name,\n      normalized_product_name: current.normalized_product_name,\n      product_key: current.product_key,\n      old_price: oldPrice,\n      old_price_num: oldPriceNum,\n      new_price: current.price,\n      new_price_num: newPriceNum,\n      diff,\n      diff_percent: diffPercent === null ? null : Number(diffPercent.toFixed(2)),\n      changed,\n      isNew: !latest,\n    },\n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
