    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction escapeHtml(value) {\n  return String(value || '')\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;');\n}\n\nfunction formatRub(value) {\n  const number = Number(value);\n  if (!Number.isFinite(number)) return '';\n  return `${Math.round(number).toLocaleString('ru-RU')} руб.`;\n}\n\nconst fetchProducts = async (ids) => {\n  const uniqueIds = [...new Set(ids)].filter(Boolean);\n  const products = [];\n\n  for (let index = 0; index < uniqueIds.length; index += 50) {\n    const batch = uniqueIds.slice(index, index + 50);\n    const payload = await this.helpers.httpRequest({\n      method: 'GET',\n      url: `https://gadjet-crimea.ru/products_by_id/${batch.join(',')}.json`,\n      json: true,\n    });\n\n    products.push(...(payload.products || []));\n  }\n\n  return products;\n};\n\nconst result = [];\n\nfor (const item of items) {\n  if (item.json.competitor !== 'Gadjet Sevastopol') {\n    result.push(item);\n    continue;\n  }\n\n  const sourceHtml = String(item.json.data || '');\n  const productIds = [...sourceHtml.matchAll(/data-product-id=[\"'](\\d+)[\"']/g)].map(match => match[1]);\n  const products = await fetchProducts(productIds);\n\n  const cards = products\n    .map((product) => {\n      const variant = Array.isArray(product.variants) ? product.variants[0] : null;\n      const price = variant ? formatRub(variant.price) : '';\n\n      if (!product.title || !price) return '';\n\n      return `<article class=\"parsed-product\"><a class=\"name\">${escapeHtml(product.title)}</a><div class=\"price price-gift\">${escapeHtml(price)}</div></article>`;\n    })\n    .filter(Boolean)\n    .join('\\n');\n\n  result.push({\n    json: {\n      ...item.json,\n      data: cards || sourceHtml,\n      name_selector: '.parsed-product .name',\n      price_selector: '.parsed-product .price',\n      extracted_product_ids: productIds.length,\n      extracted_products_with_prices: products.length,\n    },\n  });\n}\n\nreturn result;\n"
      },
